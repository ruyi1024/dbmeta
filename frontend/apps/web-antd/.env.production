VITE_BASE=/public/static/

# 开源/发行构建为 false，仅打包商业占位页；本地开发勿设 false（见 .env.development）
VITE_COMMERCIAL_FULL_UI=false

# 接口地址（生产构建走同源后端）
VITE_GLOB_API_URL=/api

# 是否开启压缩，可以设置为 none, brotli, gzip
VITE_COMPRESS=none

# 是否开启 PWA
VITE_PWA=false

# vue-router 的模式
VITE_ROUTER_HISTORY=hash

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true

# 打包后是否生成dist.zip
VITE_ARCHIVER=true
