# 端口号
VITE_PORT=5666

VITE_BASE=/

# 接口地址
VITE_GLOB_API_URL=/api

# 开发时 dev server 将 /api 代理到该后端（默认开源 :8086）。联调企业版请改为 http://127.0.0.1:8088 并重启 pnpm dev
VITE_PROXY_TARGET=http://127.0.0.1:8086

# 联调企业版完整商业 UI（数据安全 / 审计 / 洞察）。仅发行构建在 .env.production 中设为 false
VITE_COMMERCIAL_FULL_UI=true

# 是否开启 Nitro Mock服务，true 为开启，false 为关闭
VITE_NITRO_MOCK=false

# 是否打开 devtools，true 为打开，false 为关闭
VITE_DEVTOOLS=false

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true
